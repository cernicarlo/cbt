                <material name="Neutral"/>
                <mass value="4.5"/>
                <look name="black"/>
                <compound_transform rpy="1.57 1.57 1.57" xyz="0.0 0.0 0.0"/>
            </internal_part> -->

			

		</base_link>


		<!--   THRUSTERS   -->
		<!-- T1 -->
		<actuator name="Thruster_U" type="thruster">
		  <origin rpy="1.57 0.0 0.0" xyz="-0.0 0.26 0.0245"/>
			<specs thrust_coeff="0.3" torque_coeff="0.02" max_rpm="2800.0" inverted="false"/>
			<propeller diameter="0.112" right="true">
				<mesh filename="opti_blueboat/propeller2.obj" scale="0.001"/>
				<material name="Neutral"/>
				<look name="transparent"/>
			</propeller>
			<link name="Vehicle"/>
		</actuator>

		<actuator name="Thruster_D" type="thruster">
		  <origin rpy="0.0 0.0 0.07" xyz="-0.0 -0.2 0.0245"/>
			<specs thrust_coeff="0.3" torque_coeff="0.01" max_rpm="2800.0" inverted="false"/>
			<propeller diameter="0.112" right="true">
				<mesh filename="opti_blueboat/propeller_cc.obj" scale="0.001"/>
				<material name="Neutral"/>
				<look name="transparent"/>
			</propeller>
			<link name="Vehicle"/>
		</actuator>

		<actuator name="Thruster_R" type="thruster">
		  <origin rpy="1.57 0.0 0.0" xyz="0.0 0.0 -0.1245"/>
			<specs thrust_coeff="0.3" torque_coeff="0.01" max_rpm="2800.0" inverted="false"/>
			<propeller diameter="0.112" right="true">
				<mesh filename="opti_blueboat/propeller2.obj" scale="0.001"/>
				<material name="Neutral"/>
				<look name="transparent"/>
			</propeller>
			<link name="Vehicle"/>
		</actuator>

		<actuator name="Thruster_L" type="thruster">
		  <origin rpy="0.0 0.0 0.07" xyz="0.0 -0.0 0.1245"/>
			<specs thrust_coeff="0.3" torque_coeff="0.01" max_rpm="2800.0" inverted="false"/>
			<propeller diameter="0.112" right="true">
				<mesh filename="opti_blueboat/propeller_cc.obj" scale="0.001"/>
				<material name="Neutral"/>
				<look name="transparent"/>
			</propeller>
			<link name="Vehicle"/>
		</actuator>

		<!-- <world_transform rpy="0.0 0.0 0.0" xyz="0.750 3.0 2.5"/> -->
		<world_transform rpy="-1.5 0.0 0.0" xyz="0.6 3. 2.75"/>
		<!-- <world_transform rpy="0.0 0.0 0.0" xyz="2.0 4.0 0.0"/> -->

		<!--   ROS SUBSCRIBERS / PUBLISHER THRUST/FORCES   -->
		<ros_subscriber thrusters="/fish/controller/thruster_setpoints_sim" forces="/fish/controller/thruster_manager/input_stamped"/>
		<ros_publisher thrusters="/fish/controller/thruster_state" forces="/fish/controller/thruster_manager/output"/>
		<ros_base_link_transforms publish="true"/>
	</robot>


	        
</scenario>