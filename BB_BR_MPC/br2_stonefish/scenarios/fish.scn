				<mass value="1.45"/>
				<look name="black"/>
				<compound_transform rpy="1.57 1.57 1.57" xyz="0.0 0.0 0.0"/>
			</internal_part> -->
			
			
			<internal_part name="BuoyantCylinderCL" type="cylinder" physics="submerged" buoyant="true">
				<dimensions radius="0.05" height="0.4155"/>
				<origin rpy="0.0 0.0 0.0" xyz="0.0 0.05 0.0"/>
				<material name="Neutral"/>
				<mass value="0.68825"/>
				<look name="black"/>
				<compound_transform rpy="1.57 1.57 1.57" xyz=".2 0.2 -0.10"/>
			</internal_part>
			<internal_part name="BuoyantCylinderCR" type="cylinder" physics="submerged" buoyant="true">
				<dimensions radius="0.05" height="0.4155"/>
				<origin rpy="0.0 0.0 0.0" xyz="0.0 0.05 0.0"/>
				<material name="Neutral"/>
				<mass value="0.68825"/>
				<look name="black"/>
				<compound_transform rpy="1.57 1.57 1.57" xyz=".2 0.2 0.10"/>
			</internal_part>
			<!-- <internal_part name="BuoyantCylinderC" type="cylinder" physics="submerged" buoyant="true">
				<dimensions radius="0.05" height="0.2155"/>
				<origin rpy="0.0 0.0 0.0" xyz="0.0 1.0 0.0"/>
