<root BTCPP_format="4" >

     <BehaviorTree ID="MainTree">
        <Fallback name="root">
            <Sequence name="execute_mission">
                <SaySomething   message="Performing deocclusion maneuvers - mission started..." />
                <Sequence>
                    <!-- <IsBatteryOK   name="battery_ok"/> -->
                    <TransitionToPoseNode goal="0.5;2.0;2.5;0.0;0.0;-90"/> <!-- Anode right-->
                    <TransitionToPoseNode goal="0.5;2.0;4.0;0.0;0.0;90"/>
                    <TransitionToPoseNode goal="0.5;2.0;2.5;0.0;0.0;0"/>
                    <DeoccludeFishNode fish_name="fish"/>
                    <TransitionToPoseNode goal="0.5;3.0;3.5;0.0;0.0;0"/>
                    <Sleep msec="1000"/>
                    <CheckNoOccluder target_name="anode" occluder_name="fish"/>
                    <SaySomething   message="Fish is not here anymore" />
                </Sequence>
                <SaySomething   message="Inspect Node - ok..." />
                <SaySomething   message="Inspect Node - mission completed" />
            </Sequence>
            <ReactiveSequence name="go_home">
                <!-- TODO: isRobotHome -->
                <Parallel success_count="1" failure_count="2">
                    <TransitionToPoseNode goal="0.0;0.0;2.0;0.0;0.0;0.0"/>
                    <FollowBlueRovNode tol_pos="0.5" />
                </Parallel>
            </ReactiveSequence>
        </Fallback>
     </BehaviorTree>

 </root> 
